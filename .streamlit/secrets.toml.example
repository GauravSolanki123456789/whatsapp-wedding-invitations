# Copy to Streamlit Cloud → Settings → Secrets
# Enables sync across all staff phones (scan, gifts, lists, families)

# Supabase: Project Settings → Database → Connection string → URI
# Use "Session pooler" or direct connection (port 5432)
DATABASE_URL = "postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres"

# Optional — WhatsApp Cloud API bulk send
# WHATSAPP_ACCESS_TOKEN = "..."
# WHATSAPP_PHONE_NUMBER_ID = "..."

# Optional — Twilio voice calls
# TWILIO_ACCOUNT_SID = "..."
# TWILIO_AUTH_TOKEN = "..."
# TWILIO_CALL_FROM_NUMBER = "+91..."
